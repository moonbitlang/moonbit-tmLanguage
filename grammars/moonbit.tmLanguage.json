        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.block.moonbit"
        }
      },
      "patterns": [
        {
          "include": "#type-object-member"
        },
        {
          "include": "#type-inner"
        },
