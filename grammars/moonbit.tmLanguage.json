        },
        {
          "include": "#bind-default"
        },
        {
          "include": "#const-bind-object"
        },
        {
          "include": "#const-bind-array"
        },
        {
          "match": "([a-zA-Z_\\u0080-\\uFFFF\\p{L}\\p{Nl}][a-zA-Z0-9_\\u0080-\\uFFFF\\p{L}\\p{Nl}\\p{Nd}\\p{Mn}\\p{Mc}\\p{Pc}]*)",
          "name": "variable.other.constant.moonbit"
        },
        {
          "match": ",",
