      ]
    },
    "fn-definition": {
      "match": "\\b(fn)\\s+([a-zA-Z_\\u0080-\\uFFFF\\p{L}\\p{Nl}][a-zA-Z0-9_\\u0080-\\uFFFF\\p{L}\\p{Nl}\\p{Nd}\\p{Mn}\\p{Mc}\\p{Pc}]*)",
